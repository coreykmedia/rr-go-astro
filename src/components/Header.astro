---
const nav = [
  { label: 'About', href: 'https://redefiningretirement.io/about', external: true },
  { label: 'Newsletters', href: '/topics/newsletters/', external: false },
  { label: 'Creator Tools', href: '/topics/creator-tools/', external: false },
  { label: 'AI Resources', href: '/topics/ai-resources/', external: false },
  { label: 'Resources', href: '/resources/', external: false },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label="Redefining Retirement home">
      <img src="/logo-tape.png" alt="Redefining Retirement" class="logo-img" />
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul>
        {nav.map(({ label, href, external }) => (
          <li>
            <a
              href={href}
              class={!external && currentPath.startsWith(href) ? 'active' : ''}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="https://redefiningretirement.io/#subscribe"
      class="btn header-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Join Us!
    </a>
  </div>
</header>

<style>
  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 44px;
    width: auto;
    display: block;
  }

  .site-nav {
    flex: 1;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  .site-nav a {
    color: var(--text-muted);
    font-family: var(--font);
    font-weight: 500;
    font-size: 0.875rem;
    transition: color 0.15s;
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--black);
    text-decoration: none;
  }

  .header-cta {
    font-size: 0.82rem;
    padding: 0.5em 1.25em;
    border-radius: 20px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .site-nav {
      display: none;
    }
    .header-inner {
      justify-content: space-between;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 36px;
    }
  }
</style>
