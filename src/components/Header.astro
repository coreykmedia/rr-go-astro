---
const currentPath = Astro.url.pathname;

const navCenter = [
  { label: 'About', href: 'https://redefiningretirement.io/c/about', external: true },
  { label: 'Start Here', href: 'https://redefiningretirement.io/c/gen-exit-playbook', external: true },
  { label: 'Tools', href: 'https://redefiningretirement.io/c/solopreneur-business-resources-tools-courses', external: true },
  { label: 'Podcast', href: 'https://redefiningretirement.io/podcast', external: true },
];
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="site-logo" aria-label="Redefining Retirement home">
      <img src="/rr-logo.jpg" alt="Redefining Retirement" class="logo-img" />
    </a>

    <!-- Center nav -->
    <nav class="site-nav" aria-label="Main navigation">
      <ul>
        {navCenter.map(({ label, href, external }) => (
          <li>
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right actions -->
    <div class="header-actions">
      <button class="search-btn" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true">
          <circle cx="112" cy="112" r="80" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
          <line x1="168.57" y1="168.57" x2="224" y2="224" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
        </svg>
        <span>Search</span>
      </button>
      <a
        href="https://redefiningretirement.io/login"
        class="login-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Login
      </a>
      <a
        href="https://redefiningretirement.io/subscribe"
        class="btn btn--pill header-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Join Us!
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: #ffffff;
    width: 100%;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 10px 1.5rem;
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* Logo — left */
  .site-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: auto;
  }

  .logo-img {
    height: 36px;
    width: auto;
    display: block;
  }

  /* Center nav */
  .site-nav {
    display: flex;
    align-items: center;
    margin: 0 auto;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .site-nav a {
    color: #0B0A0A;
    font-family: var(--font);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0;
    padding: 2px 4px;
    border-radius: var(--radius);
    transition: color 0.15s;
    text-decoration: none;
    display: block;
  }

  .site-nav a:hover {
    color: var(--blue);
    text-decoration: none;
  }

  /* Right actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .search-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    color: #a3a3a3;
    font-family: var(--font);
    font-size: 14px;
    padding: 8px;
    border-radius: var(--radius);
    transition: color 0.15s;
  }

  .search-btn:hover {
    color: var(--text);
  }

  .login-link {
    color: #0B0A0A;
    font-family: var(--font);
    font-size: 16px;
    font-weight: 500;
    padding: 4px 8px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: color 0.15s;
  }

  .login-link:hover {
    color: var(--blue);
    text-decoration: none;
  }

  .header-cta {
    font-size: 14px;
    height: 36px;
    padding: 0 12px;
  }

  @media (max-width: 768px) {
    .site-nav {
      display: none;
    }
    .search-btn span {
      display: none;
    }
    .login-link {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 30px;
    }
  }
</style>
