---
const nav = [
  { label: 'Newsletters', href: '/topics/newsletters/' },
  { label: 'Creator Tools', href: '/topics/creator-tools/' },
  { label: 'AI Resources', href: '/topics/ai-resources/' },
  { label: 'Resources', href: '/resources/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label="Redefining Retirement home">
      <span class="logo-rx">Rx</span>
      <span class="logo-text">
        <span class="logo-redefining">REDEFINING</span>
        <span class="logo-retirement">retirement</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul>
        {nav.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class={currentPath.startsWith(href) ? 'active' : ''}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="https://redefiningretirement.io/#subscribe"
      class="btn header-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get the Newsletter
    </a>
  </div>
</header>

<style>
  .site-header {
    background: var(--black);
    border-bottom: 1px solid #222;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-rx {
    background: var(--cream);
    color: var(--blue);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.3rem;
    padding: 0.1em 0.35em;
    line-height: 1;
    transform: rotate(-2deg);
    display: inline-block;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .logo-redefining {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.9rem;
    color: var(--blue);
    letter-spacing: 0.05em;
  }

  .logo-retirement {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 0.75rem;
    color: var(--cream);
    letter-spacing: 0.02em;
  }

  .site-nav {
    flex: 1;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  .site-nav a {
    color: #aaa;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s;
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--white);
  }

  .header-cta {
    font-size: 0.8rem;
    padding: 0.5em 1.2em;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .site-nav {
      display: none;
    }

    .header-inner {
      justify-content: space-between;
    }
  }

  @media (max-width: 480px) {
    .header-cta {
      display: none;
    }
  }
</style>
