---
const topics = [
  { label: 'Newsletters', href: '/topics/newsletters/' },
  { label: 'Creator Tools', href: '/topics/creator-tools/' },
  { label: 'AI Resources', href: '/topics/ai-resources/' },
];

const resources = [
  { label: 'Beehiiv vs. Substack', href: '/compare/beehiiv-vs-substack/' },
  { label: 'Move Your Audience to Email', href: '/guides/move-your-audience-to-a-newsletter/' },
  { label: 'All Resources', href: '/resources/' },
];
---

<footer class="site-footer">
  <!-- Newsletter CTA bar — white background matching main content -->
  <div class="footer-cta-bar">
    <div class="container footer-cta-inner">
      <div class="tape-label footer-tape">Stop building on rented land.</div>
      <p>The Redefining Retirement newsletter — for Gen X creators building income they own.</p>
      <a
        href="https://redefiningretirement.io/#subscribe"
        class="btn btn-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get the Free Newsletter &rarr;
      </a>
    </div>
  </div>

  <!-- Dark footer body -->
  <div class="footer-body">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo-link">
            <img src="/logo-tape.png" alt="Redefining Retirement" class="footer-logo" />
          </a>
          <p class="footer-tagline">
            Tools and guides for Gen X creators and solopreneurs who are done building on platforms they don't control.
          </p>
          <a href="https://redefiningretirement.io" target="_blank" rel="noopener noreferrer" class="footer-main-link">
            &larr; Back to RedefiningRetirement.io
          </a>
        </div>

        <div class="footer-links">
          <div class="footer-col">
            <h4>Topics</h4>
            <ul>
              {topics.map(({ label, href }) => (
                <li><a href={href}>{label}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-col">
            <h4>Resources</h4>
            <ul>
              {resources.map(({ label, href }) => (
                <li><a href={href}>{label}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Redefining Retirement &middot; Corey Koehler</p>
        <p class="footer-disclaimer">This site contains affiliate links. We may earn a small commission if you purchase — at no extra cost to you.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-cta-bar {
    background: var(--white);
    border-top: 1px solid var(--border);
    padding: 3rem 0;
  }

  .footer-cta-inner {
    text-align: center;
  }

  .footer-tape {
    margin-bottom: 1rem;
    font-size: 1.1rem !important;
    display: inline-block;
  }

  .footer-cta-inner p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .btn-cta {
    border-radius: 20px;
  }

  .footer-body {
    background: var(--footer-bg);
    padding: 2.5rem 0 1.5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #2a2a2a;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    margin-bottom: 1rem;
    /* the tape logo on dark bg — lighten it */
    filter: brightness(1.1) contrast(0.95);
  }

  .footer-tagline {
    color: #777;
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 320px;
  }

  .footer-main-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--blue);
    text-decoration: none;
  }

  .footer-main-link:hover {
    text-decoration: underline;
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-content: start;
  }

  .footer-col h4 {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
    margin-bottom: 0.75rem;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col li {
    margin-bottom: 0.45rem;
  }

  .footer-col a {
    color: #555;
    font-size: 0.85rem;
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer-col a:hover {
    color: var(--white);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    text-align: center;
  }

  .footer-bottom p {
    color: #444;
    font-size: 0.78rem;
    margin-bottom: 0.3rem;
  }

  .footer-disclaimer {
    color: #333 !important;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
