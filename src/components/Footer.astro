<style>
  .site-footer {
    background: var(--footer-bg);
    padding: 2.5rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer-logo-link {
    display: inline-block;
    text-decoration: none;
  }

  .footer-logo {
    height: 36px;
    width: auto;
    display: block;
    opacity: 0.85;
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-socials a {
    color: #a3a3a3;
    display: flex;
    align-items: center;
    transition: color 0.15s;
    text-decoration: none;
  }

  .footer-socials a:hover {
    color: #ffffff;
    text-decoration: none;
  }

  .footer-legal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-legal p {
    color: #6B7280;
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    color: #6B7280;
    font-size: 0.78rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: #ffffff;
    text-decoration: none;
  }

  .footer-powered {
    color: #4B5563 !important;
    font-size: 0.75rem !important;
  }

  .footer-powered a {
    color: #6B7280;
    text-decoration: none;
  }

  .footer-powered a:hover {
    color: #ffffff;
  }
</style>
