---
import Layout from '../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Creator Resources | Redefining Retirement",
  "url": "https://start.redefiningretirement.io/resources/",
  "description": "All guides, comparisons, and tools for Gen X creators and solopreneurs building audiences they own.",
  "isPartOf": {
    "@type": "WebSite",
    "url": "https://start.redefiningretirement.io"
  }
};

const comparisons = [
  {
    title: 'Beehiiv vs. Substack: An Honest Breakdown',
    desc: 'The real differences in pricing, monetization, and who each platform is actually built for — without the affiliate spin.',
    href: 'https://redefiningretirement.io/p/beehiiv-vs-substack-newsletter-platform-comparison?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Comparison',
  },
  {
    title: 'LinkedIn Newsletter vs. Email Newsletter',
    desc: "You don't own your LinkedIn audience. Here's what that actually means — and what to do about it.",
    href: 'https://redefiningretirement.io/p/linkedin-newsletter-vs-email-newsletter?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Comparison',
  },
  {
    title: 'Beehiiv Review 2025: Pricing and Promo Code',
    desc: 'A straight look at what Beehiiv costs, what you get, and whether it makes sense for where you are right now.',
    href: 'https://redefiningretirement.io/p/beehiiv-review-2025-pricing-and-promo?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Review',
  },
  {
    title: 'Riverside.fm Review',
    desc: 'Is Riverside worth it for solo podcasters and video creators? An honest look at what it does well and where it falls short.',
    href: 'https://redefiningretirement.io/p/riverside-fm-review?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Review',
  },
];

const guides = [
  {
    title: 'How to Monetize a Newsletter in 2025',
    desc: 'Six income streams Gen X creators are using to turn an email list into real recurring revenue.',
    href: 'https://redefiningretirement.io/p/how-to-monetize-a-newsletter-2025-gen-x-creators-income-guide?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Guide',
  },
  {
    title: 'AI Newsletter Fast Track',
    desc: 'A step-by-step guide to using AI to build and grow a newsletter faster than going it alone.',
    href: 'https://redefiningretirement.io/p/ai-newsletter-fast-track-step-by-step-guide?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Guide',
  },
  {
    title: 'Affiliate Marketing for Gen X',
    desc: 'How to build an affiliate income stream that fits the way Gen X actually works — without the hustle-culture nonsense.',
    href: 'https://redefiningretirement.io/p/affiliate-marketing-for-gen-x?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Guide',
  },
  {
    title: 'What Is a Blogletter? A Complete Guide',
    desc: 'The case for running a blog and a newsletter as one thing — and why it might be the smartest content model for solopreneurs.',
    href: 'https://redefiningretirement.io/p/what-is-a-blogletter-a-complete-guide-for-beginners?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    tag: 'Guide',
  },
];

const topics = [
  {
    title: 'Solopreneur Tools',
    href: 'https://redefiningretirement.io/c/solopreneur-business-resources-tools-courses?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    desc: 'The software stack that actually matters — newsletter platforms, podcast gear, AI tools, and more.',
  },
  {
    title: 'Gen Exit Playbook',
    href: 'https://redefiningretirement.io/c/gen-exit-playbook?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    desc: 'Free strategy guide for Gen X — how to build income and independence before you have to retire.',
  },
  {
    title: 'Newsletter Resources',
    href: 'https://redefiningretirement.io/p/how-to-monetize-a-newsletter-2025-gen-x-creators-income-guide?utm_source=start-here&utm_medium=referral&utm_campaign=resources-page',
    desc: 'Platform comparisons, growth strategies, and monetization guides for building an email audience you own.',
  },
];
---

<Layout
  title="All Resources for Creators and Solopreneurs | Redefining Retirement"
  description="All guides, comparisons, and tools for Gen X creators and solopreneurs building audiences and income they own."
  schema={schema}
>
  <div class="section">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span>&rsaquo;</span> Resources
      </div>

      <div class="resources-header">
        <span class="tag">All Resources</span>
        <p class="resources-intro">
          Guides, comparisons, and tools for creators and solopreneurs who are done
          building on platforms they don't control.
        </p>
      </div>

      <h2 class="group-heading"><span class="blue-dot"></span>Comparisons</h2>
      <div class="card-grid">
        {comparisons.map(({ title, desc, href, tag }) => (
          <a href={href} class="card card--link" target="_blank" rel="noopener noreferrer">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link">Read &rarr;</span>
          </a>
        ))}
      </div>

      <h2 class="group-heading"><span class="blue-dot"></span>Guides</h2>
      <div class="card-grid">
        {guides.map(({ title, desc, href, tag }) => (
          <a href={href} class="card card--link" target="_blank" rel="noopener noreferrer">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link">Read &rarr;</span>
          </a>
        ))}
      </div>

      <h2 class="group-heading"><span class="blue-dot"></span>Browse by Topic</h2>
      <div class="card-grid">
        {topics.map(({ title, href, desc }) => (
          <a href={href} class="card card--link" target="_blank" rel="noopener noreferrer">
            <span class="tag">Topic</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link">Explore &rarr;</span>
          </a>
        ))}
      </div>

      <div class="cta-block">
        <h2>New resources every week in the newsletter</h2>
        <p>
          The Redefining Retirement newsletter goes deeper than the site.
          Tactics, case studies, and honest takes on building creator income as a Gen X solopreneur.
        </p>
        <a
          href="https://redefiningretirement.io/subscribe"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get the Free Newsletter &rarr;
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .resources-header {
    margin-bottom: 2.5rem;
  }

  .resources-intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 580px;
    line-height: 1.65;
    margin-top: 0.5rem;
  }

  .group-heading {
    font-size: 1.1rem;
    color: var(--text);
    margin: 2.5rem 0 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--blue);
    font-family: var(--font);
    font-weight: 700;
  }
</style>
