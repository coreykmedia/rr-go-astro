---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Redefining Retirement — Start Here",
  "url": "https://start.redefiningretirement.io",
  "description": "Tools, guides, comparisons, and newsletter resources for Gen X creators building audience-owned income.",
  "publisher": {
    "@type": "Organization",
    "name": "Redefining Retirement",
    "url": "https://redefiningretirement.io"
  }
};

const pathways = [
  {
    label: 'Newsletter Resources',
    desc: 'Platform comparisons, growth strategies, and monetization guides for building an email audience you actually own.',
    href: 'https://redefiningretirement.io/p/how-to-monetize-a-newsletter-2025-gen-x-creators-income-guide?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
  },
  {
    label: 'Solopreneur Tools',
    desc: 'The software stack that actually matters — newsletter platforms, podcast gear, AI tools, and more.',
    href: 'https://redefiningretirement.io/c/solopreneur-business-resources-tools-courses?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
  },
  {
    label: 'AI Newsletter Fast Track',
    desc: 'A step-by-step guide to using AI to build and grow a newsletter faster than going it alone.',
    href: 'https://redefiningretirement.io/p/ai-newsletter-fast-track-step-by-step-guide?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
  },
  {
    label: 'Gen Exit Playbook',
    desc: 'Free strategy guide for Gen X — how to build income and independence before you have to retire.',
    href: 'https://redefiningretirement.io/c/gen-exit-playbook?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
  },
];

const featured = [
  {
    tag: 'Comparison',
    title: 'Beehiiv vs. Substack: An Honest Breakdown',
    desc: 'The real differences in pricing, monetization, and who each platform is actually built for — without the affiliate spin.',
    href: 'https://redefiningretirement.io/p/beehiiv-vs-substack-newsletter-platform-comparison?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
    cta: 'Read the comparison &rarr;',
  },
  {
    tag: 'Guide',
    title: 'LinkedIn Newsletter vs. Email Newsletter',
    desc: 'You don\'t own your LinkedIn audience. Here\'s what that actually means — and what to do about it.',
    href: 'https://redefiningretirement.io/p/linkedin-newsletter-vs-email-newsletter?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
    cta: 'Read the guide &rarr;',
  },
  {
    tag: 'Guide',
    title: 'How to Monetize a Newsletter in 2025',
    desc: 'Six income streams Gen X creators are using to turn an email list into real recurring revenue.',
    href: 'https://redefiningretirement.io/p/how-to-monetize-a-newsletter-2025-gen-x-creators-income-guide?utm_source=start-here&utm_medium=referral&utm_campaign=start-page',
    cta: 'Read the guide &rarr;',
  },
];
---

<Layout
  title="Start Here | Redefining Retirement"
  description="Tools, guides, and resources for Gen X creators building work they never want to retire from. The best place to start."
  schema={schema}
>

  <!-- SECTION 1: Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-photo">
        <img
          src="/images/corey-portrait.jpg"
          alt="Corey Koehler — Redefining Retirement"
          class="portrait"
        />
      </div>
      <div class="hero-content">
        <p class="section-heading">Start Here</p>
        <h1>I never planned to retire. I planned to stop needing to.</h1>
        <p class="hero-sub">
          I'm Corey. Blue-collar kid, Class of '90, singer-songwriter, accidental entrepreneur.
          I've reinvented myself more times than I can count and I'm still going.
          This is where I share what I've figured out along the way.
        </p>
        <div class="hero-ctas">
          <a href="https://redefiningretirement.io/subscribe" class="btn" target="_blank" rel="noopener noreferrer">
            Join the newsletter — free
          </a>
          <a href="/resources/" class="btn btn--outline">Browse the resources</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Philosophy / About -->
  <section class="section about-section">
    <div class="container">
      <div class="about-inner">
        <p class="section-heading">How I think about this</p>
        <h2 class="about-heading">Retirement isn't the finish line. It's just when you stop having to ask permission.</h2>
        <div class="about-body">
          <p class="about-lead">
            I grew up a latchkey kid in the 80s. Nobody was managing my afternoon. That kind of
            independence gets into your blood.
          </p>

          <p>
            I spent years doing what you're supposed to do. Punched the clock, built the skills,
            showed up. Then I started figuring something out.
          </p>
          <p>
            If you build the right kind of work — work that generates income whether you're at your
            desk or not — you get to choose whether you retire. That's a completely different thing
            than saving enough to survive stopping.
          </p>
          <p>
            Build once, earn twice. Three times. Ten times. Email lists, newsletters, digital assets.
            Things you create one time that keep paying. The music analogy I always come back to:
            you record a song once and people can listen to it forever. That's the model.
          </p>

          <p class="about-closer">
            I'm not here because I figured it all out at 30. I'm figuring it out at 51, same as
            you. Blue-collar to cubicle to Company of One. If I can do it, you can too.
          </p>
        </div>
        <div class="about-byline">
          <img src="/images/corey-portrait.jpg" alt="Corey Koehler" class="byline-photo" />
          <span class="byline-name">Corey Koehler</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Start Here Pathways -->
  <section class="section pathways-section">
    <div class="container">
      <p class="section-heading">Where do you want to start?</p>
      <h2 class="section-title">Start Here</h2>
      <div class="pathways-grid">
        {pathways.map(({ label, desc, href }) => (
          <a href={href} class="pathway-card" target="_blank" rel="noopener noreferrer">
            <h3>{label}</h3>
            <p>{desc}</p>
            <span class="pathway-cta">Explore &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 4: Featured Resources -->
  <section class="section featured-section">
    <div class="container">
      <p class="section-heading">Useful things</p>
      <h2 class="section-title">Resources Worth Bookmarking</h2>
      <p class="section-desc">Comparison guides, frameworks, and practical tools — picked for clarity, not clicks.</p>
      <div class="card-grid card-grid--3">
        {featured.map(({ tag, title, desc, href, cta }) => (
          <a href={href} class="card card--link" target="_blank" rel="noopener noreferrer">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link" set:html={cta} />
          </a>
        ))}
      </div>
      <p class="section-footer-link"><a href="/resources/">See all guides &rarr;</a></p>
    </div>
  </section>

  <!-- SECTION 5: Bridge to Main Site -->
  <section class="section bridge-section">
    <div class="container">
      <div class="cta-block">
        <p class="section-heading">The full picture</p>
        <h2>More on RedefiningRetirement.io</h2>
        <p>
          This site is the resource hub — guides, comparisons, and tools you can browse and bookmark.
          The newsletter and main editorial home lives at RedefiningRetirement.io. That's where I
          publish deeper thinking, reader questions, and the ongoing conversation about what
          retirement can actually look like for people like us. If this is your first visit,
          that's the best place to go next.
        </p>
        <a
          href="https://redefiningretirement.io"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit RedefiningRetirement.io &rarr;
        </a>
        <p class="cta-footnote">Free newsletter. No pitch. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .hero-photo {
    flex-shrink: 0;
  }

  .portrait {
    width: 100%;
    max-width: 280px;
    border-radius: var(--radius);
    object-fit: cover;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--border);
  }

  .hero-content h1 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.75rem;
    max-width: 520px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

/* ── About ── */
  .about-section {
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }

  .about-inner {
    max-width: 680px;
  }

  .about-heading {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    margin-bottom: 1.5rem;
    margin-top: 0.5rem;
    line-height: 1.3;
  }

  .about-body p {
    margin-bottom: 1rem;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .about-body p:last-child {
    margin-bottom: 0;
  }

  .about-lead {
    font-size: 1.1rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .about-closer {
    font-size: 1.05rem;
    color: var(--text);
    font-weight: 500;
    margin-top: 0.5rem;
  }

  .about-byline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .byline-photo {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .byline-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  /* ── Section titles ── */
  .section-title {
    margin-bottom: 0.5rem;
    margin-top: 0.25rem;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.75rem;
    max-width: 540px;
  }

  .section-footer-link {
    margin-top: 1.5rem;
    font-size: 0.9rem;
  }

  /* ── Pathways ── */
  .pathways-section {
    border-bottom: 1px solid var(--border);
  }

  .pathways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
    margin-top: 1.5rem;
  }

  .pathway-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .pathway-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: var(--blue);
    text-decoration: none;
  }

  .pathway-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .pathway-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .pathway-cta {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--blue);
    margin-top: 0.5rem;
  }

  /* ── Featured ── */
  .featured-section {
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }

  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--blue);
  }

  .card-grid--3 {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  /* ── Bridge ── */
  .bridge-section {
    background: var(--body-bg);
  }

  .cta-footnote {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .portrait {
      max-width: 180px;
    }

    .hero-photo {
      display: flex;
      justify-content: center;
    }

    .hero-content {
      text-align: center;
    }

    .hero-sub {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-ctas {
      justify-content: center;
      flex-direction: column;
      align-items: center;
    }

    .hero-ctas .btn {
      width: 100%;
      max-width: 320px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2.5rem 0 2rem;
    }

    .pathways-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 420px) {
    .pathways-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
