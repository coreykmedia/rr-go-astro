---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Redefining Retirement — Creator Resources",
  "url": "https://go.redefiningretirement.io",
  "description": "Tools, comparisons, and guides for Gen X creators and solopreneurs who want to own their audience.",
  "publisher": {
    "@type": "Organization",
    "name": "Redefining Retirement",
    "url": "https://redefiningretirement.io"
  }
};

const topics = [
  {
    tag: 'Topic',
    title: 'Newsletters',
    desc: 'Platform comparisons, growth strategies, and monetization guides for creators building email-first audiences.',
    href: '/topics/newsletters/',
  },
  {
    tag: 'Topic',
    title: 'Creator Tools',
    desc: 'The software stack that actually matters — tools for building, growing, and monetizing without burning out.',
    href: '/topics/creator-tools/',
  },
  {
    tag: 'Topic',
    title: 'AI Resources',
    desc: 'How Gen X creators are using AI to do more with less — without losing the human voice that built their audience.',
    href: '/topics/ai-resources/',
  },
];

const featured = [
  {
    tag: 'Comparison',
    title: 'Beehiiv vs. Substack',
    desc: 'Which newsletter platform is actually worth your time? We break down pricing, features, and who each one is really built for.',
    href: '/compare/beehiiv-vs-substack/',
    cta: 'Read the comparison &rarr;',
  },
  {
    tag: 'Guide',
    title: 'Move Your Audience to a Newsletter',
    desc: "You've built a following on a platform you don't own. Here's the step-by-step playbook to move them to email — without losing momentum.",
    href: '/guides/move-your-audience-to-a-newsletter/',
    cta: 'Read the guide &rarr;',
  },
];
---

<Layout
  title="Creator Resources for Gen X Solopreneurs | Redefining Retirement"
  description="Tools, comparisons, and guides for Gen X creators and solopreneurs who want to own their audience — not rent it from platforms."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-container">
      <div class="hero-inner">
        <div class="tape-label hero-tape">Your audience isn't yours.</div>
        <h1 class="hero-headline">Not until you own the list.</h1>
        <p class="hero-body">
          You've put years into building a following on platforms that can change the rules tomorrow.
          This site is about fixing that — honest tools, real comparisons, and guides that skip the hype.
        </p>
        <div class="hero-actions">
          <a href="/resources/" class="btn">Browse Resources</a>
          <a
            href="https://redefiningretirement.io/#subscribe"
            class="btn btn--outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get the Newsletter
          </a>
        </div>
      </div>
      <div class="hero-img">
        <img src="/logo-full.png" alt="Redefining Retirement" />
      </div>
    </div>
  </section>

  <!-- Topics -->
  <section class="section section--alt">
    <div class="container">
      <span class="section-heading">Topics</span>
      <div class="card-grid">
        {topics.map(({ tag, title, desc, href }) => (
          <a href={href} class="card card--link">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link">Explore {title} &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Start Here -->
  <section class="section">
    <div class="container">
      <span class="section-heading">Start Here</span>
      <div class="card-grid">
        {featured.map(({ tag, title, desc, href, cta }) => (
          <a href={href} class="card card--link">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link" set:html={cta} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section section--alt">
    <div class="container">
      <div class="cta-block">
        <div class="tape-label cta-tape">Gen eXit Playbook</div>
        <h2>Build income that doesn't depend on the algorithm</h2>
        <p>
          The Redefining Retirement newsletter covers how Gen X creators and solopreneurs
          are building audiences they own and income streams that compound.
          No fluff. No retirement golf metaphors.
        </p>
        <a
          href="https://redefiningretirement.io/#subscribe"
          class="btn btn-round"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get the Free Newsletter &rarr;
        </a>
        <p class="cta-footnote">Join creators who are done building on rented land.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--white);
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-container {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-inner {
    flex: 1;
  }

  .hero-tape {
    margin-bottom: 1rem;
    display: inline-block;
  }

  .hero-headline {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    font-weight: 900;
    color: var(--black);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .hero-body {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 2rem;
    line-height: 1.7;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-img {
    flex-shrink: 0;
    width: 260px;
  }

  .hero-img img {
    width: 100%;
    height: auto;
  }

  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--blue-dark);
  }

  .cta-tape {
    font-size: 1rem !important;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .cta-footnote {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .btn-round {
    border-radius: 20px;
  }

  @media (max-width: 768px) {
    .hero-container {
      flex-direction: column-reverse;
      gap: 2rem;
    }
    .hero-img {
      width: 180px;
      align-self: center;
    }
  }
</style>
