---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Redefining Retirement — Start Here",
  "url": "https://start.redefiningretirement.io",
  "description": "Tools, guides, comparisons, and newsletter resources for Gen X creators building audience-owned income.",
  "publisher": {
    "@type": "Organization",
    "name": "Redefining Retirement",
    "url": "https://redefiningretirement.io"
  }
};

const quickLinks = [
  {
    label: 'Subscribe to the Newsletter',
    href: 'https://redefiningretirement.io/subscribe',
    external: true,
    icon: '✉️',
  },
  {
    label: 'Browse All Resources',
    href: '/resources/',
    external: false,
    icon: '📚',
  },
  {
    label: 'Beehiiv vs. Substack — Full Comparison',
    href: '/compare/beehiiv-vs-substack/',
    external: false,
    icon: '⚖️',
  },
  {
    label: 'Move Your Audience to a Newsletter',
    href: '/guides/move-your-audience-to-a-newsletter/',
    external: false,
    icon: '🗺️',
  },
  {
    label: 'Creator Tools Stack',
    href: '/topics/creator-tools/',
    external: false,
    icon: '🛠️',
  },
  {
    label: 'AI Resources for Creators',
    href: '/topics/ai-resources/',
    external: false,
    icon: '🤖',
  },
  {
    label: 'Newsletter Platform Reviews',
    href: '/topics/newsletters/',
    external: false,
    icon: '📰',
  },
  {
    label: 'Listen to the Podcast',
    href: 'https://redefiningretirement.io/podcast',
    external: true,
    icon: '🎙️',
  },
];

const featured = [
  {
    tag: 'Comparison',
    title: 'Beehiiv vs. Substack for creators who want more control',
    desc: 'A practical comparison for creators who want more ownership, better monetization options, and room to grow.',
    href: '/compare/beehiiv-vs-substack/',
    cta: 'Read the comparison &rarr;',
  },
  {
    tag: 'Guide',
    title: 'How to move your audience off social and onto a newsletter',
    desc: 'A plain-English guide to turning rented attention into an audience you actually own.',
    href: '/guides/move-your-audience-to-a-newsletter/',
    cta: 'Read the guide &rarr;',
  },
  {
    tag: 'Tools',
    title: 'My creator tools stack for newsletters, podcasting, and YouTube',
    desc: 'The handful of tools I use, test, or recommend to make content creation and distribution easier.',
    href: '/topics/creator-tools/',
    cta: 'See the stack &rarr;',
  },
];
---

<Layout
  title="Start Here | Redefining Retirement"
  description="Tools, guides, comparisons, and newsletter resources for Gen X creators building audience-owned income. The best place to start."
  schema={schema}
>

  <!-- Link-in-bio hero -->
  <section class="bio-hero">
    <div class="bio-inner">
      <img
        src="/rr-logo.jpg"
        alt="Redefining Retirement"
        class="bio-logo"
      />
      <h1 class="bio-headline">Redefining Retirement</h1>
      <p class="bio-sub">
        Tools, guides, and resources for Gen X creators building audience-owned income —
        the kind you never want to retire from.
      </p>

      <!-- Quick links -->
      <ul class="link-list" role="list">
        {quickLinks.map(({ label, href, external, icon }) => (
          <li>
            <a
              href={href}
              class="link-row"
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              <span class="link-icon" aria-hidden="true">{icon}</span>
              <span class="link-label">{label}</span>
              <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Featured resources -->
  <section class="section featured-section">
    <div class="container">
      <p class="section-heading">Featured Resources</p>
      <div class="card-grid card-grid--3">
        {featured.map(({ tag, title, desc, href, cta }) => (
          <a href={href} class="card card--link">
            <span class="tag">{tag}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span class="card-link" set:html={cta} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bridge back to main site -->
  <section class="section">
    <div class="container">
      <div class="cta-block">
        <h2>The full newsletter and archive live on the main site</h2>
        <p>
          The full Redefining Retirement newsletter, archive, and bigger story still live on the main site.
          Use this page to find your best next step fast — then head there when you're ready to go deeper.
        </p>
        <a
          href="https://redefiningretirement.io"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Go to RedefiningRetirement.io &rarr;
        </a>
        <p class="cta-footnote">Newsletter · Archive · Podcast · Community</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Bio Hero ── */
  .bio-hero {
    background: var(--body-bg);
    padding: 3rem 1.5rem 2rem;
    display: flex;
    justify-content: center;
  }

  .bio-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 560px;
    width: 100%;
    gap: 0;
  }

  .bio-logo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 2px solid var(--border);
  }

  .bio-headline {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .bio-sub {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 440px;
    margin-bottom: 1.75rem;
  }

  /* ── Link List ── */
  .link-list {
    list-style: none;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .link-row {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    text-decoration: none;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 500;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .link-row:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    border-color: var(--blue);
    text-decoration: none;
    color: var(--text);
  }

  .link-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .link-label {
    flex: 1;
    text-align: left;
  }

  .link-arrow {
    color: var(--text-light);
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .link-row:hover .link-arrow {
    color: var(--blue);
  }

  /* ── Featured Section ── */
  .featured-section {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }

  .card--link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--blue);
  }

  .card-grid--3 {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .cta-footnote {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  @media (max-width: 640px) {
    .bio-hero {
      padding: 2rem 1.25rem 1.5rem;
    }

    .bio-headline {
      font-size: 20px;
    }
  }
</style>
